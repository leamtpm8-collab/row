# Copy to .env.local for local dev (never commit the real file — see .gitignore).
# In production these live in Vercel → Project Settings → Environment Variables.

# --- Login (api/login.js, middleware.js) ---
AUTH_EMAIL=
AUTH_PASSWORD_HASH=
AUTH_SECRET=

# --- WHOOP OAuth (api/whoop-callback.js, api/whoop-refresh.js) ---
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=

# --- Push notifications (api/push-send.js, vercel.json crons) ---
CRON_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# --- External automation sync (Apple Health Shortcuts) ---
NUTRITION_SYNC_SECRET=
FITNESS_SYNC_SECRET=

# --- Supabase (server-side only; the browser never holds a Supabase key) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
